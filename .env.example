# --- ตอน build บนเครื่อง (Vite) — เปิดใช้ Turso ผ่าน /api/kv/* ---
# ใส่แค่บรรทัดนี้ใน .env — อย่าใส่ TURSO_* ใน .env (Vite ไม่ส่งต่อให้ Functions; โทเคนจะไม่ควรอยู่ใน bundle)
# VITE_USE_TURSO=1
#
# Cloudflare Pages: ถ้า Dashboard บอกว่า env ธรรมดาจัดการผ่าน wrangler.toml (ใส่ใน UI ได้แค่ Secret)
# โปรเจกต์นี้มี VITE_USE_TURSO ใน wrangler.toml [vars] และไฟล์ .env.production แล้ว — push แล้ว redeploy


# รหัสหน้าประตูก่อนเข้าแอป (ค่าเริ่มต้นในโค้ด 111555 ถ้าไม่ตั้ง)
# VITE_APP_ACCESS_CODE=111555

# --- ทดสอบ local กับ wrangler pages dev: คัดลอกเป็น .dev.vars (อย่า commit) ---
# TURSO_DATABASE_URL=libsql://your-db-org.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# --- บน Cloudflare Pages → Settings → Environment variables ---
# (Production และ Preview ใส่เหมือนกันได้)
# TURSO_DATABASE_URL   = libsql://...
# TURSO_AUTH_TOKEN     = (token จาก turso db tokens create)
# VITE_USE_TURSO       = 1
